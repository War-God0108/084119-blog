---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';
import { formatDate } from '../../utils/date';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);
---

<BaseLayout title="文章" path="/blog">
  <div class="container-narrow">
    <section class="blog-header">
      <h1 class="page-title">文章</h1>
      <p class="page-subtitle">记录思考，分享所学。</p>
    </section>

    <div class="post-list">
      {posts.map((post) => (
        <article class="post-card">
          <a href={`/blog/${post.id}`} class="post-card-link">
            <h2 class="post-card-title">{post.data.title}</h2>
            <p class="post-card-desc">{post.data.description}</p>
            <div class="post-card-meta">
              <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt)}</time>
            </div>
            {post.data.tags.length > 0 && (
              <div class="post-card-tags">
                {post.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
              </div>
            )}
          </a>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .blog-header {
    padding: 3rem 0 2rem;
  }

  .page-title {
    font-size: 2.25rem;
    margin-bottom: 0.25em;
  }

  .page-subtitle {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
  }

  .post-card {
    margin-bottom: 2rem;
  }

  .post-card-link {
    display: block;
    text-decoration: none;
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .post-card-link:hover {
    border-color: var(--color-accent);
    box-shadow: 0 2px 12px var(--color-card-shadow);
    text-decoration: none;
  }

  .post-card-title {
    font-size: 1.25rem;
    margin: 0 0 0.35em;
    color: var(--color-text);
    transition: color 0.2s ease;
  }

  .post-card-link:hover .post-card-title {
    color: var(--color-accent);
  }

  .post-card-desc {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    margin-bottom: 0.75em;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-meta {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.5em;
  }

  .post-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.8rem;
    padding: 0.15em 0.55em;
    border-radius: 4px;
    background: var(--color-bg-alt);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }
</style>
